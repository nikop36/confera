meta {
  name: Register user
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/auth/register
  body: json
  auth: none
}

body:json {
  {
    "email": "testuser@confera.com",
    "password": "TestPassword1!",
    "displayName": "Test User"
  }
}

assert {
  res.status: eq 201
  res.body.uid: isDefined
  res.body.email: eq testuser@confera.com
  res.body.role: eq participant
}