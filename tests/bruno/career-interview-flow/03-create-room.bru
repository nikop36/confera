meta {
  name: Organizer creates a room
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/scheduling/rooms
  body: json
  auth: bearer
}

auth:bearer {
  token: {{organizerToken}}
}

body:json {
  {
    "name": "Bruno Test Room",
    "location": "Building A",
    "capacity": 4,
    "active": true
  }
}

assert {
  res.status: eq 201
  res.body.id: isDefined
  res.body.name: eq Bruno Test Room
}

script:post-response {
  bru.setVar("roomId", res.body.id);
}