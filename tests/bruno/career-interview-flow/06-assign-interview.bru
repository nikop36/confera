meta {
  name: Admin assigns interview to organizer with room and slot
  type: http
  seq: 6
}

patch {
  url: {{baseUrl}}/career-interviews/{{interviewId}}/assign
  body: json
  auth: bearer
}

auth:bearer {
  token: {{adminToken}}
}

body:json {
  {
    "interviewerUid": "{{organizerUid}}",
    "roomId": "{{roomId}}",
    "slotId": "{{slotId}}"
  }
}

assert {
  res.status: eq 200
  res.body.message: isDefined
}