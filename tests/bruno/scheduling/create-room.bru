meta {
  name: Create room
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/scheduling/rooms
  body: json
  auth: bearer
}

auth:bearer {
  token: {{adminToken}}
}

body:json {
  {
    "name": "Room A",
    "capacity": 10,
    "active": true
  }
}

assert {
  res.status: eq 201
  res.body.id: isDefined
  res.body.name: eq Room A
}

script:post-response {
  bru.setVar("roomId", res.body.id);
}