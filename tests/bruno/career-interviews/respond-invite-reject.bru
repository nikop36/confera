meta {
  name: Respond to invite - reject causes cancellation
  type: http
  seq: 3
}

patch {
  url: {{baseUrl}}/career-interviews/{{interviewId}}/respond
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "action": "rejected"
  }
}

assert {
  res.status: eq 200
}